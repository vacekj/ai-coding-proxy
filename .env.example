# Optional server binding.
HOST=127.0.0.1
PORT=8317

# Grok Composer defaults. The proxy reads OAuth credentials from the Grok CLI.
GROK_PROXY_MODEL=grok-composer-2.5-fast
GROK_CLI_AUTH_FILE=~/.grok/auth.json

# Optional OpenCode Zen settings.
# OPENCODE_API_KEY=
# OPENCODE_PROXY_MODEL=minimax-m3-free
# PROXY_PROVIDER=opencode

# Optional request compaction knobs for huge tool results.
PROXY_MAX_TOOL_RESULT_CHARS=24000
PROXY_MAX_REQUEST_CHARS=200000
PROXY_COMPACTED_TOOL_RESULT_CHARS=4000
